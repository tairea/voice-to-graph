# Copy this file to `.env` and fill in your keys:
#   cp .env.example .env

# ─── Required ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...                # Realtime voice + extract shim (https://platform.openai.com/api-keys)
ANTHROPIC_API_KEY=sk-ant-...         # PHAROS resolver (https://console.anthropic.com/settings/keys)

# ─── Optional ────────────────────────────────────────────────────────────────
PORT=3002                            # default port

# Network sync target. Leave commented to use the hosted relay (default),
# set to empty for fully offline mode (no P2P sharing), or point at your own.
# GUN_RELAY_URL=https://experiments.sunriselabs.io/gun
# GUN_RELAY_URL=                     # offline mode
# GUN_RELAY_URL=http://localhost:8765/gun  # self-hosted relay

# PHAROS_NAME=Ian                    # friendly name shown in your profile
# RESOLVE_MODEL=claude-sonnet-4-6    # override resolver model
# EXTRACT_MODEL=gpt-4.1-mini         # override extract-shim model
